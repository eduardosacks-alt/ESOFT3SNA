#include <stdio.h>
#include <stdlib.h>


typedef struct No {
    char dado;
    struct No *proximo;
} No;


void push(No **topo, char valor) {
    No *novo = (No*) malloc(sizeof(No));
    if (novo) {
        novo->dado = valor;
        novo->proximo = *topo;
        *topo = novo;
    }
}

char pop(No **topo) {
    if (*topo == NULL) return '\0';
    No *temp = *topo;
    char valor = temp->dado;
    *topo = temp->proximo;
    free(temp);
    return valor;
}

int isEmpty(No *topo) {
    return topo == NULL;
}

